package config

import (
	"os"
)

// PWD is initialized to the parent working directory of your app
var PWD string = "."

// IsRoot returns true if the EUID is 0
//
// (i.e. if you ran your app with sudo)
var IsRoot bool = os.Geteuid() == 0

// DebugMode returns true if the --debug || -d flag is used
var DebugMode bool = false

func init() {
	var err error
	PWD, err = os.Getwd()
	if err != nil {
		panic(err)
	}

	for _, arg := range os.Args[1:] {
		if arg == "--debug" || arg == "-d" {
			DebugMode = true
		}
	}
}
